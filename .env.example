# Discord bot token (from the Discord Developer Portal)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Comma-separated list of guild IDs to sync slash commands to
DISCORD_GUILD_IDS=123456789012345678

# Optional log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# === Proxmox API ===
# Hostname or IP of your Proxmox node (no protocol)
PROXMOX_HOST=proxmox.lan
# Proxmox API port (usually 8006)
PROXMOX_PORT=8006

# Proxmox API token
# Example token ID format: cartobot@pam!discord-bot
PROXMOX_TOKEN_ID=cartobot@pam!discord-bot
PROXMOX_TOKEN_SECRET=REPLACE_ME_SECRET

# Proxmox node name (as shown in the web UI)
PROXMOX_NODE=proxmox

# CT ID for Cartofia game container (your CT2000)
PROXMOX_CT_CARTOFIA_ID=2000

# Verify SSL certificates? (true/false)
PROXMOX_VERIFY_SSL=false

# === API / Archive settings ===
# Flask API bind port
API_PORT=5000

# Secret key used for login sessions (set a strong random value in production)
API_SECRET_KEY=replace-with-a-long-random-secret

# Optional comma-separated CORS origins for /api/* when frontend is on another origin
# API_ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com

# Upload limit for Cartofia Archive files
ARCHIVE_MAX_UPLOAD_MB=50

# === Bomber Raid online room settings ===
# Room is considered stale and eligible for cleanup after this many seconds
BOMBER_ROOM_STALE_SECONDS=900

# Maximum accepted room password length for Bomber Raid room joins
BOMBER_ROOM_PASSWORD_MAX_LENGTH=32
